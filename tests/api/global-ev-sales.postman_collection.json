        {
          "name": "GET con query 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Todos los resultados son del año buscado\", function () {\r",
                  "    const datos = pm.response.json();\r",
                  "    pm.expect(datos).to.be.an(\"array\");\r",
                  "    datos.forEach(function(item) {\r",
                  "        pm.expect(item.year).to.eql(2021);\r",
                  "    });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
