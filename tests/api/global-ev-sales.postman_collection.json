          "name": "GET Initial DATA 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "pm.test(\"Devuelve datos (no está vacío)\", function () {\r",
                  "    // Aunque devuelvas un 'sendStatus', si devuelves JSON puedes comprobarlo:\r",
                  "    if(pm.response.headers.get(\"Content-Type\")?.includes(\"json\")) {\r",
                  "        pm.expect(pm.response.json().length).to.be.above(0);\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
