{
  "name": "sos2526-16",
  "version": "0.0.0",
  "description": "",
  "homepage": "https://github.com/gti-sos/SOS2526-16#readme",
  "bugs": {
    "url": "https://github.com/gti-sos/SOS2526-16/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gti-sos/SOS2526-16.git"
  },
  "license": "ISC",
  "author": "Javier P",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "coverage": "cat coverage/lcov.info | coveralls",
    "test-unit": "node --test tests/unit/api.test.js",
    "start": "npm run build-all && node index.js",
    "build-all": "npm run build-svelte && npm run build-vue",
    "build-svelte": "npm --prefix src/front install --include=dev && npm --prefix src/front run build",
    "build-vue": "npm --prefix frontend-vue install --include=dev && npm --prefix frontend-vue run build",
    "dev-front": "cd src/front && npm run dev -- --open",
    "test": "nyc node --test tests/unit/api.test.js && nyc --reporter=lcov --reporter=text start-server-and-test start http://localhost:3000 test-apis-local",
    "test-apis-local": "npm run test-global-ev-charging-infrastructures && npm run test-global-ev-sales && npm run test-global-ev-stock-volumes",
    "test-global-ev-sales": "newman run ./tests/api/api-test-IMM.json -e ./tests/api/api-test-env-local.json",
    "test-global-ev-charging-infrastructures": "newman run ./tests/api/api-test-JPA.json -e ./tests/api/api-test-env-local.json",
    "test-global-ev-stock-volumes": "newman run ./tests/api/api-test-ARH.json -e ./tests/api/api-test-env-local.json"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cool-ascii-faces": "^1.3.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nedb": "^1.8.0",
    "npx": "^10.2.2",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "coveralls": "^3.1.1",
    "newman": "^6.2.2",
    "nyc": "^18.0.0",
    "start-server-and-test": "^2.1.5",
    "supertest": "^7.2.2",
    "wait-on": "^9.0.4"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text"
    ],
    "report-dir": "./coverage",
    "all": true
  }
}
